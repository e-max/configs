#!/bin/bash
list=$(tmux list-sessions | sed -E 's/:.*$//')
if [ -n "$TMUX" ]; then
  current=$(tmux display-message -p '#S')
  list=$(echo "$list" | grep -v "^${current}$")
fi

sess=$(echo "$list" | nl | fzf --reverse | awk '{print $2}')
if [ -n "$sess" ]; then
  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$sess"
  else
    tmux attach-session -dt "$sess"
  fi
else
  echo "session not selected"
fi
